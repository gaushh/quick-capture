# Copy to .env in the repo root (never commit real keys).
OPENAI_API_KEY=

# Hosted speech-to-text (OpenAI Audio API).
WHISPER_MODEL=whisper-1

# Chat models for checklist formatting and transcript edit suggestions.
OPENAI_CHECKLIST_MODEL=gpt-4o-mini
OPENAI_EDIT_MODEL=gpt-4o-mini

# Electron devtools: set to 1 to open DevTools in development.
QUICK_CAPTURE_DEVTOOLS=0
